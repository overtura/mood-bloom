{
  "repository": "overtura/mood-bloom",
  "defaultBranch": "main",
  "worktree": "targets/overtura/mood-bloom",
  "scope": "mixed",
  "improvementKind": "auto",
  "docPaths": [
    "README.md",
    "AGENTS.md",
    "docs/project",
    "maintainer-bot"
  ],
  "evalsPath": "maintainer-bot/evals/docs_qa.jsonl",
  "projectConcept": "하루 한 문장을 로컬 의미 분류와 결정적 3D 식물 생성으로 디지털 식물과 개인 정원으로 변환하는 브라우저 기반 앱",
  "improvementFocus": [
    "첫 사용 완료율과 Future Bloom Reveal",
    "진화 단계 이해와 재방문 동기",
    "로컬 모델 다운로드와 fallback",
    "식물과 정원 시각 품질",
    "결정적 seed와 preview 무상태",
    "접근성, reduced motion, 모바일",
    "데이터 export/import와 복구",
    "코드 단순성과 테스트 가능성",
    "새로운 식물 archetype과 정원 기능",
    "월간 정원과 공유 결과물"
  ],
  "avoidTopics": [
    "backend, API route, database, authentication",
    "외부 AI API와 사용자 문장 외부 전송",
    "심리 진단과 의료적 해석",
    "소셜 피드, 결제, 푸시 알림",
    "generic AI dashboard와 chat UI",
    "불필요한 architecture layer와 dependency",
    "model weight 또는 대형 binary 저장",
    "징벌적 streak와 dark pattern"
  ],
  "verifyCommands": [
    "pnpm install --frozen-lockfile || pnpm install",
    "pnpm check"
  ],
  "allowPaths": [
    "README.md",
    "AGENTS.md",
    "docs/**",
    "maintainer-bot/**",
    "prompts/**",
    "issues/**",
    "src/**",
    "tests/**",
    "public/**",
    "package.json",
    "pnpm-lock.yaml",
    "vite.config.*",
    "vercel.json",
    "tsconfig*.json",
    "eslint.config.*",
    "playwright.config.*",
    "vitest.config.*"
  ],
  "denyPaths": [
    ".github/workflows/**",
    ".github/CODEOWNERS",
    "CODEOWNERS",
    ".env*",
    ".npmrc",
    "api/**",
    "server/**",
    "backend/**",
    "functions/**",
    "infra/**",
    "terraform/**",
    "k8s/**",
    "migrations/**",
    "**/auth/**",
    "**/security/**",
    "public/models/**",
    "**/*.onnx",
    "**/*.safetensors",
    "**/*.bin",
    "**/*.pem",
    "**/*.key"
  ],
  "maxFiles": 24,
  "maxLines": 1200,
  "autoMerge": true
}
